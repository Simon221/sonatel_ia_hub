# ─────────────────────────────────────────────────────────────
# Sonatel IA Hub — Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs
# ─────────────────────────────────────────────────────────────

# ── Serveur ───────────────────────────────────────────────────
SERVER_HOST=localhost
SERVER_PORT=8000
# Ouvrir le navigateur automatiquement au démarrage (true/false)
AUTO_OPEN_BROWSER=true

# ── Authentification SSO (Keycloak + Active Directory) ────────
# URL de base de votre instance Keycloak
KEYCLOAK_URL=https://keycloak.sonatel.sn
# Nom du realm Keycloak configuré avec le fédérateur AD
KEYCLOAK_REALM=sonatel
# Client ID créé dans Keycloak pour cette application
KEYCLOAK_CLIENT_ID=ia-hub
# Secret du client (Keycloak > Clients > ia-hub > Credentials)
KEYCLOAK_CLIENT_SECRET=CHANGEZ_MOI

# URL publique de cette application (utilisée comme redirect_uri)
APP_BASE_URL=http://localhost:8000

# Clé secrète pour signer les cookies de session (générer avec : python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=CHANGEZ_MOI_AUSSI

# Nom du cookie de session (optionnel)
SESSION_COOKIE=sso_session
# Durée de session en secondes (défaut: 28800 = 8h)
SESSION_MAX_AGE=28800
# Tolérance horloge en secondes pour la validation JWT (défaut: 30)
AUTH_CLOCK_SKEW=30
# Forcer l'activation/désactivation de l'auth (optionnel, auto-détecté si absent)
# AUTH_ENABLED=true

# ── URLs des applications ─────────────────────────────────────
APP_CHATBOT_URL=http://localhost:8501
APP_DOCUMENTS_URL=http://localhost:8502
APP_ANALYTICS_URL=http://localhost:8503
APP_FRAUDE_URL=http://localhost:8504
APP_OCR_URL=http://localhost:8505
APP_CHURN_URL=http://localhost:8506
APP_RAPPORTS_URL=http://localhost:8507
APP_MAINTENANCE_URL=http://localhost:8508

# ── Base de données PostgreSQL (espace admin + projets dynamiques) ──
# Format : postgresql://utilisateur:motdepasse@hote:5432/nom_base
# Exemple local : postgresql://postgres:secret@localhost:5432/sonatel_ia_hub
DATABASE_URL=postgresql://postgres:secret@localhost:5432/sonatel_ia_hub

# ── Contrôle d'accès à l'espace admin ────────────────────────
# Groupes Keycloak autorisés (virgule-séparé). Laisser vide = tous les utilisateurs authentifiés.
ADMIN_GROUPS=
# Logins spécifiques autorisés (preferred_username, virgule-séparé).
ADMIN_USERS=

